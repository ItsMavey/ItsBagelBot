---
import logoImage from "../../assets/LogoBOT.png";
import {Image} from "astro:assets";

import Button from '../ui/Buttons/SecondaryButton.astro'
---

<nav>
    <div class="logo">
        <Image src={logoImage} alt="ItsBagelBot Logo" width={35} height={35} fetchpriority="high"/>
        <span>ItsBagelBot</span>
    </div>
    <ul class="links">
        <li><a href="#features">Features</a></li>
        <li><a href="#how">Setup</a></li>
        <li><a href="#privacy">Privacy</a></li>
        <li><a href="#docs">Docs</a></li>
    </ul>

    <div class="button">
        <Button href="#" label="Add to Twitch"/>
    </div>

</nav>

<style>
    nav {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        font-family: "Syne", sans-serif;

        position: fixed;
        top: 0;

        padding: 0 4%;
        width: 100%;
        height: 10vh;

        border-bottom: var(--border) 1px solid;

        z-index: 50;

        backdrop-filter: blur(12px);
        background: rgba(10, 10, 10, 0.7);
    }

    .logo {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 10px;
    }

    .logo span {
        font-family: "Syne", sans-serif;
        font-weight: 700;
        font-size: 1.1rem;
        letter-spacing: -0.02em;
        color: var(--white);
    }

    ul {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap: 35px;
        padding: 0 2rem;
        list-style: none;
        margin: 0;
    }

    ul a {
        font-family: "DM Mono", monospace;
        font-size: 0.78rem;
        color: var(--muted);
        text-decoration: none;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        transition: color 0.2s;
    }

    ul a:hover {
        color: var(--tan-light);
    }

    .button {
        display: flex;
        justify-content: flex-end;
        align-items: center;
    }
</style>