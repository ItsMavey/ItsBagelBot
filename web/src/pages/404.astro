---
import Base from "../layouts/layout.astro";
---

<Base title="404 — Lost in the Stream | ItsBagelBot">
    <div class="page-404">

        <!-- Background -->
        <div class="bg-grid" aria-hidden="true"></div>
        <div class="bg-vignette" aria-hidden="true"></div>
        <div class="scanline" aria-hidden="true"></div>

        <!-- Giant 404 -->
        <div class="hero-numerals" aria-hidden="true">
            <span class="numeral n4 n4-left">4</span>
            <div class="numeral-zero-wrap">
                <span class="numeral n0">0</span>
                <!-- Bot face inside the zero -->
                <div class="bot-face">
                    <svg viewBox="0 0 60 44" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="4" y="8" width="52" height="32" rx="8" fill="#1a1a18" stroke="#c9a87c" stroke-width="1.5"/>
                        <!-- Antenna -->
                        <line x1="30" y1="8" x2="30" y2="0" stroke="#c9a87c" stroke-width="1.5" stroke-linecap="round"/>
                        <circle cx="30" cy="0" r="2.5" fill="#52b788"/>
                        <!-- Eyes -->
                        <rect x="12" y="16" width="12" height="10" rx="3" fill="#0a0a0a" stroke="#c9a87c" stroke-width="1"/>
                        <rect x="36" y="16" width="12" height="10" rx="3" fill="#0a0a0a" stroke="#c9a87c" stroke-width="1"/>
                        <!-- Pupils — looking confused (up-left) -->
                        <circle cx="16" cy="19" r="3" fill="#52b788"/>
                        <circle cx="40" cy="19" r="3" fill="#52b788"/>
                        <!-- Sweat drop -->
                        <path d="M50 10 Q52 7 54 10 Q54 14 50 14 Q46 14 46 10 Q48 7 50 10Z" fill="#4a9edd" opacity="0.7"/>
                        <!-- Mouth — flat/confused line -->
                        <path d="M20 32 Q25 30 30 32 Q35 30 40 32" stroke="#c9a87c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
                    </svg>
                </div>
                <!-- Glitch slices on the 0 -->
                <div class="glitch-slices" aria-hidden="true">
                    <div class="gs gs1"></div>
                    <div class="gs gs2"></div>
                    <div class="gs gs3"></div>
                </div>
            </div>
            <span class="numeral n4 n4-right">4</span>
        </div>

        <!-- Broken chain decoration -->
        <div class="broken-chain" aria-hidden="true">
            <svg viewBox="0 0 700 48" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
                <!-- Left chain half -->
                <g class="chain-left">
                    <ellipse cx="30"  cy="24" rx="22" ry="13" stroke="#3a3020" stroke-width="3"/>
                    <ellipse cx="72"  cy="24" rx="13" ry="22" stroke="#3a3020" stroke-width="3"/>
                    <ellipse cx="114" cy="24" rx="22" ry="13" stroke="#3a3020" stroke-width="3"/>
                    <ellipse cx="156" cy="24" rx="13" ry="22" stroke="#3a3020" stroke-width="3"/>
                    <ellipse cx="198" cy="24" rx="22" ry="13" stroke="#3a3020" stroke-width="3"/>
                    <ellipse cx="240" cy="24" rx="13" ry="22" stroke="#3a3020" stroke-width="3"/>
                    <ellipse cx="282" cy="24" rx="22" ry="13" stroke="#4a3828" stroke-width="3"/>
                    <!-- Last link — broken, glowing -->
                    <ellipse cx="324" cy="24" rx="13" ry="22" stroke="#c9a87c" stroke-width="2.5" stroke-dasharray="6 4" opacity="0.6"/>
                </g>
                <!-- Right chain half (mirrored) -->
                <g class="chain-right">
                    <ellipse cx="670" cy="24" rx="22" ry="13" stroke="#3a3020" stroke-width="3"/>
                    <ellipse cx="628" cy="24" rx="13" ry="22" stroke="#3a3020" stroke-width="3"/>
                    <ellipse cx="586" cy="24" rx="22" ry="13" stroke="#3a3020" stroke-width="3"/>
                    <ellipse cx="544" cy="24" rx="13" ry="22" stroke="#3a3020" stroke-width="3"/>
                    <ellipse cx="502" cy="24" rx="22" ry="13" stroke="#3a3020" stroke-width="3"/>
                    <ellipse cx="460" cy="24" rx="13" ry="22" stroke="#3a3020" stroke-width="3"/>
                    <ellipse cx="418" cy="24" rx="22" ry="13" stroke="#4a3828" stroke-width="3"/>
                    <!-- Last link — broken, glowing -->
                    <ellipse cx="376" cy="24" rx="13" ry="22" stroke="#c9a87c" stroke-width="2.5" stroke-dasharray="6 4" opacity="0.6"/>
                </g>
                <!-- Break sparks in the gap -->
                <g class="break-sparks">
                    <line x1="340" y1="18" x2="348" y2="10" stroke="#e0c49a" stroke-width="1.5" stroke-linecap="round" opacity="0.8"/>
                    <line x1="350" y1="24" x2="360" y2="16" stroke="#52b788" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
                    <line x1="344" y1="30" x2="352" y2="38" stroke="#e0c49a" stroke-width="1.5" stroke-linecap="round" opacity="0.8"/>
                    <line x1="356" y1="28" x2="366" y2="34" stroke="#52b788" stroke-width="1" stroke-linecap="round" opacity="0.6"/>
                    <circle cx="350" cy="22" r="2" fill="#c9a87c" opacity="0.9"/>
                    <circle cx="358" cy="28" r="1.5" fill="#52b788" opacity="0.7"/>
                </g>
            </svg>
        </div>

        <!-- Text content -->
        <div class="content">
            <p class="error-code">ERROR_404</p>
            <h1 class="headline">Page not found.</h1>
            <p class="subline">
                Looks like this link is as broken as that chain.<br />
                The page you're looking for doesn't exist — or never did.
            </p>
            <div class="actions">
                <a href="/" class="btn-primary">Back to home</a>
                <a href="#" class="btn-secondary">Open Discord</a>
            </div>
        </div>

        <!-- Corner decorations -->
        <div class="corner corner-tl" aria-hidden="true"></div>
        <div class="corner corner-tr" aria-hidden="true"></div>
        <div class="corner corner-bl" aria-hidden="true"></div>
        <div class="corner corner-br" aria-hidden="true"></div>

    </div>
</Base>

<style>
    .page-404 {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        padding: 40px 24px 80px;
        gap: 0;
    }

    /* ── Background ── */
    .scanline {
        position: fixed;
        inset: 0;
        background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 3px,
                rgba(0,0,0,0.08) 3px,
                rgba(0,0,0,0.08) 4px
        );
        pointer-events: none;
        z-index: 1;
    }

    /* ── Giant numerals ── */
    .hero-numerals {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        position: relative;
        z-index: 2;
        margin-bottom: -20px;
        animation: numeralEntrance 1s cubic-bezier(0.16,1,0.3,1) forwards;
    }

    @keyframes numeralEntrance {
        from { opacity: 0; transform: scale(0.85) translateY(30px); }
        to   { opacity: 1; transform: scale(1) translateY(0); }
    }

    .numeral {
        font-family: "Syne", sans-serif;
        font-size: clamp(180px, 28vw, 320px);
        font-weight: 800;
        line-height: 0.85;
        letter-spacing: -0.06em;
        color: transparent;
        -webkit-text-stroke: 2px rgba(201,168,124,0.2);
        position: relative;
        user-select: none;
    }

    .n4-left  { animation: slideLeft  0.9s 0.1s cubic-bezier(0.16,1,0.3,1) both; }
    .n4-right { animation: slideRight 0.9s 0.1s cubic-bezier(0.16,1,0.3,1) both; }

    @keyframes slideLeft  { from { opacity:0; transform: translateX(-60px); } to { opacity:1; transform: none; } }
    @keyframes slideRight { from { opacity:0; transform: translateX( 60px); } to { opacity:1; transform: none; } }

    .numeral-zero-wrap {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .n0 {
        -webkit-text-stroke: 2px rgba(201,168,124,0.35);
        color: transparent;
        position: relative;
    }

    /* Bot face inside the zero */
    .bot-face {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -52%);
        width: clamp(60px, 9vw, 110px);
        animation: botBob 3s ease-in-out infinite;
        z-index: 3;
        filter: drop-shadow(0 0 12px rgba(82,183,136,0.4));
    }

    @keyframes botBob {
        0%, 100% { transform: translate(-50%, -52%); }
        50%       { transform: translate(-50%, -58%); }
    }

    /* Glitch slices */
    .glitch-slices {
        position: absolute;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        z-index: 4;
    }

    .gs {
        position: absolute;
        left: 0; right: 0;
        background: rgba(82,183,136,0.15);
        mix-blend-mode: screen;
        opacity: 0;
        transition: none;
    }
    .gs1 { top: 20%; height: 8px; }
    .gs2 { top: 48%; height: 5px; background: rgba(201,168,124,0.2); }
    .gs3 { top: 70%; height: 10px; }

    /* ── Broken chain ── */
    .broken-chain {
        width: min(700px, 95vw);
        position: relative;
        z-index: 2;
        margin-bottom: 8px;
        animation: chainFade 1s 0.5s ease both;
    }

    @keyframes chainFade { from { opacity:0; transform: scaleX(0.9); } to { opacity:1; transform: none; } }

    .chain-left  { animation: chainSlideL 1s 0.3s cubic-bezier(0.16,1,0.3,1) both; }
    .chain-right { animation: chainSlideR 1s 0.3s cubic-bezier(0.16,1,0.3,1) both; }

    @keyframes chainSlideL { from { transform: translateX(-40px); opacity:0; } to { transform: none; opacity:1; } }
    @keyframes chainSlideR { from { transform: translateX( 40px); opacity:0; } to { transform: none; opacity:1; } }

    /* ── Content ── */
    .content {
        text-align: center;
        position: relative;
        z-index: 2;
        animation: contentUp 0.9s 0.7s cubic-bezier(0.16,1,0.3,1) both;
        padding-top: 32px;
    }

    @keyframes contentUp { from { opacity:0; transform: translateY(24px); } to { opacity:1; transform: none; } }

    .error-code {
        font-family: "DM Mono", monospace;
        font-size: 0.72rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--green-glow);
        margin-bottom: 16px;
    }

    .headline {
        font-family: "Syne", sans-serif;
        font-size: clamp(2rem, 5vw, 4rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1;
        margin-bottom: 20px;
        color: var(--white);
    }

    .subline {
        font-size: 0.95rem;
        line-height: 1.75;
        color: #6a6560;
        margin-bottom: 44px;
        max-width: 440px;
        margin-left: auto;
        margin-right: auto;
    }

    .actions {
        display: flex;
        gap: 16px;
        justify-content: center;
        align-items: center;
    }

    .btn-primary {
        font-family: "Syne", sans-serif;
        font-weight: 700;
        font-size: 0.95rem;
        padding: 14px 32px;
        background: var(--tan);
        color: var(--black);
        border-radius: 4px;
        text-decoration: none;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
        display: inline-block;
    }
    .btn-primary:hover {
        background: var(--tan-light);
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(201,168,124,0.25);
    }

    .btn-secondary {
        font-family: "DM Mono", monospace;
        font-size: 0.82rem;
        color: var(--muted);
        text-decoration: none;
        letter-spacing: 0.04em;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: color 0.2s;
    }
    .btn-secondary::after { content: "→"; transition: transform 0.2s; }
    .btn-secondary:hover { color: var(--white); }
    .btn-secondary:hover::after { transform: translateX(4px); }

    /* ── Corner brackets ── */
    .corner {
        position: fixed;
        width: 40px;
        height: 40px;
        border-color: rgba(201,168,124,0.15);
        border-style: solid;
        pointer-events: none;
        z-index: 2;
    }
    .corner-tl { top: 24px; left: 24px;  border-width: 1px 0 0 1px; }
    .corner-tr { top: 24px; right: 24px; border-width: 1px 1px 0 0; }
    .corner-bl { bottom: 24px; left: 24px;  border-width: 0 0 1px 1px; }
    .corner-br { bottom: 24px; right: 24px; border-width: 0 1px 1px 0; }

    /* Cursor */
    .cursor { position: fixed; width: 12px; height: 12px; background: var(--tan); border-radius: 50%; pointer-events: none; z-index: 9999; transform: translate(-50%,-50%); mix-blend-mode: difference; }
    .cursor-ring { position: fixed; width: 36px; height: 36px; border: 1.5px solid var(--tan); border-radius: 50%; pointer-events: none; z-index: 9998; transform: translate(-50%,-50%); opacity: 0.5; }

    @media (max-width: 600px) {
        .actions { flex-direction: column; }
        .corner { display: none; }
        .cursor, .cursor-ring { display: none; }
    }
</style>